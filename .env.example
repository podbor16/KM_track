# KM Track — шаблон переменных окружения
# Скопировать в .env и заполнить значения: cp .env.example .env

# База данных MySQL (внешний сервер)
DB_HOST=
DB_PORT=16171
DB_NAME=krasmarafon
DB_USER=
DB_PASSWORD=

# Администратор (страница /business-analytics)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Безопасность
SECRET_KEY=

# DataLens (бизнес-аналитика)
DATALENS_KEY_SECRET=
DATALENS_EMBEDS=

# Режим запуска
DEBUG=False
HOST=127.0.0.1
PORT=8000
